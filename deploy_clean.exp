#!/usr/bin/expect -f
set timeout 1200
set password [lindex $argv 0]
spawn ssh -o StrictHostKeyChecking=no root@76.13.20.44
expect "*?assword:*" {
    send "$password\r"
}
expect -re "(#|\\$)" {
    send "cd ~/erp && git pull origin main && rm -rf .next && npm run build && pm2 restart all --update-env\r"
}
expect -re "(#|\\$)" {
    send "exit\r"
}
expect eof
