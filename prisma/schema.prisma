generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  name              String?
  email             String               @unique
  emailVerified     DateTime?
  image             String?
  role              String               @default("USER")
  password          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  accounts          Account[]
  customers         Customer[]           @relation("CustomerCreatedBy")
  financeTrans      FinanceTransaction[] @relation("FTCreatedBy")
  goodsReceipts     GoodsReceipt[]       @relation("GRCreatedBy")
  journals          JournalEntry[]       @relation("JournalCreatedBy")
  notifications     Notification[]       @relation("NotificationAuthor")
  products          Product[]            @relation("ProductCreatedBy")
  approvedRequests  PurchaseRequest[]    @relation("ApprovedBy")
  requestedRequests PurchaseRequest[]    @relation("RequestedBy")
  verifiedRequests  PurchaseRequest[]    @relation("VerifiedBy")
  purchaseReturns   PurchaseReturn[]     @relation("PRCreatedBy")
  salesDeliveries   SalesDelivery[]      @relation("SDCreatedBy")
  salesOrders       SalesOrder[]         @relation("SOCreatedBy")
  salesReturns      SalesReturn[]        @relation("SRCreatedBy")
  sessions          Session[]
  vendors           Vendor[]             @relation("VendorCreatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinanceAccount {
  id       String         @id @default(cuid())
  code     String         @unique
  name     String
  type     String
  journals JournalEntry[]
}

model JournalEntry {
  id            String              @id @default(cuid())
  date          DateTime            @default(now())
  description   String
  amount        Decimal
  type          String
  accountId     String
  transactionId String?
  createdById   String?
  account       FinanceAccount      @relation(fields: [accountId], references: [id])
  createdBy     User?               @relation("JournalCreatedBy", fields: [createdById], references: [id])
  transaction   FinanceTransaction? @relation(fields: [transactionId], references: [id])

  @@index([date])
  @@index([accountId])
  @@index([createdById])
}

model FinanceTransaction {
  id              String         @id @default(cuid())
  transactionType String
  bank            String
  date            DateTime
  referenceNumber String?
  description     String
  amount          Decimal
  category        String?
  salesPerson     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdById     String?
  createdBy       User?          @relation("FTCreatedBy", fields: [createdById], references: [id])
  journals        JournalEntry[]

  @@index([date])
  @@index([createdAt])
  @@index([createdById])
}

model Vendor {
  id             String          @id @default(cuid())
  code           String?         @unique
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  province       String?
  postalCode     String?
  npwp           String?
  taxName        String?
  balance        Decimal         @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String?
  purchaseOrders PurchaseOrder[]
  createdBy      User?           @relation("VendorCreatedBy", fields: [createdById], references: [id])
}

model Customer {
  id          String   @id @default(cuid())
  code        String?  @unique
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  province    String?
  postalCode  String?
  npwp        String?
  taxName     String?
  balance     Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("CustomerCreatedBy", fields: [createdById], references: [id])
}

model PurchaseOrder {
  id        String              @id @default(cuid())
  number    String              @unique
  date      DateTime            @default(now())
  vendorId  String
  status    String              @default("PENDING")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  vendor    Vendor              @relation(fields: [vendorId], references: [id])
  items     PurchaseOrderItem[]

  @@index([number])
  @@index([date])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  price           Decimal
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  number        String                @unique
  date          DateTime              @default(now())
  status        String                @default("PENDING")
  notes         String?
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  verifiedById  String?
  verifiedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  category      String?
  salesPerson   String?
  approvedBy    User?                 @relation("ApprovedBy", fields: [approvedById], references: [id])
  requestedBy   User                  @relation("RequestedBy", fields: [requestedById], references: [id])
  verifiedBy    User?                 @relation("VerifiedBy", fields: [verifiedById], references: [id])
  items         PurchaseRequestItem[]

  @@index([status])
  @@index([createdAt])
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  itemName          String
  quantity          Int
  estimatedPrice    Decimal
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
}

model GoodsReceipt {
  id               String                     @id @default(cuid())
  receiptNumber    String                     @unique
  receivedFrom     String
  formNumber       String?                    @unique
  date             DateTime?
  taxInvoiceDate   DateTime?
  taxInvoiceNumber String?
  salesPerson      String?
  warehouseId      String
  isVerified       Boolean                    @default(false)
  verifiedAt       DateTime?
  verifiedBy       String?
  paymentStatus    String                     @default("PENDING")
  subtotal         Decimal                    @default(0)
  totalDiscount    Decimal                    @default(0)
  taxRate          Decimal                    @default(0)
  taxAmount        Decimal                    @default(0)
  grandTotal       Decimal                    @default(0)
  paidAmount       Decimal                    @default(0)
  createdAt        DateTime                   @default(now())
  createdById      String?
  isVoid           Boolean                    @default(false)
  voidReason       String?
  createdBy        User?                      @relation("GRCreatedBy", fields: [createdById], references: [id])
  warehouse        Warehouse                  @relation(fields: [warehouseId], references: [id])
  items            GoodsReceiptItem[]
  verifications    GoodsReceiptVerification[]
  returns          PurchaseReturn[]

  @@index([receiptNumber])
  @@index([createdAt])
  @@index([date])
  @@index([paymentStatus])
}

model GoodsReceiptItem {
  id            String       @id @default(cuid())
  receiptId     String
  productId     String
  quantity      Int
  purchasePrice Decimal      @default(0)
  discount      Decimal      @default(0)
  uom           String?
  product       Product      @relation(fields: [productId], references: [id])
  receipt       GoodsReceipt @relation(fields: [receiptId], references: [id])
}

model GoodsReceiptVerification {
  id               String       @id @default(cuid())
  receiptId        String
  productId        String
  expectedQuantity Int
  actualQuantity   Int
  expectedPrice    Decimal
  actualPrice      Decimal
  notes            String?
  createdAt        DateTime     @default(now())
  verifiedBy       String
  product          Product      @relation(fields: [productId], references: [id])
  receipt          GoodsReceipt @relation(fields: [receiptId], references: [id])
}

model PurchaseReturn {
  id           String               @id @default(cuid())
  returnNumber String               @unique
  date         DateTime             @default(now())
  receiptId    String
  status       String               @default("PENDING")
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdById  String?
  isVoid       Boolean              @default(false)
  voidReason   String?
  createdBy    User?                @relation("PRCreatedBy", fields: [createdById], references: [id])
  receipt      GoodsReceipt         @relation(fields: [receiptId], references: [id])
  items        PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id               String         @id @default(cuid())
  purchaseReturnId String
  productId        String
  quantity         Int
  reason           String?
  product          Product        @relation(fields: [productId], references: [id])
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
}

model SalesOrder {
  id             String           @id @default(cuid())
  orderNumber    String           @unique
  proformaNumber String?          @unique
  poNumber       String?
  status         String           @default("OPEN")
  recipient      String
  buyerName      String
  salesPerson    String?
  date           DateTime         @default(now())
  warehouseId    String
  subtotal       Decimal          @default(0)
  totalDiscount  Decimal          @default(0)
  taxRate        Decimal          @default(0)
  taxAmount      Decimal          @default(0)
  grandTotal     Decimal          @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdById    String?
  deliveries     SalesDelivery[]
  createdBy      User?            @relation("SOCreatedBy", fields: [createdById], references: [id])
  warehouse      Warehouse        @relation(fields: [warehouseId], references: [id])
  items          SalesOrderItem[]

  @@index([orderNumber])
  @@index([proformaNumber])
  @@index([createdAt])
}

model SalesOrderItem {
  id              String              @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  shippedQuantity Int                 @default(0)
  salesPrice      Decimal
  discount        Decimal             @default(0)
  uom             String?
  vendorName      String              @default("UMUM")
  deliveryItems   SalesDeliveryItem[]
  order           SalesOrder          @relation(fields: [orderId], references: [id])
  product         Product             @relation(fields: [productId], references: [id])
}

model SalesDelivery {
  id             String              @id @default(cuid())
  deliveryNumber String              @unique
  recipient      String
  buyerName      String
  salesPerson    String?
  date           DateTime            @default(now())
  warehouseId    String
  paymentStatus  String              @default("PENDING")
  subtotal       Decimal             @default(0)
  totalDiscount  Decimal             @default(0)
  taxRate        Decimal             @default(0)
  taxAmount      Decimal             @default(0)
  grandTotal     Decimal             @default(0)
  paidAmount     Decimal             @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdById    String?
  poNumber       String?
  isVoid         Boolean             @default(false)
  voidReason     String?
  vehicleNumber  String?
  orderId        String?
  createdBy      User?               @relation("SDCreatedBy", fields: [createdById], references: [id])
  order          SalesOrder?         @relation(fields: [orderId], references: [id])
  warehouse      Warehouse           @relation(fields: [warehouseId], references: [id])
  items          SalesDeliveryItem[]
  returns        SalesReturn[]

  @@index([deliveryNumber])
  @@index([createdAt])
  @@index([date])
  @@index([paymentStatus])
}

model SalesDeliveryItem {
  id               String            @id @default(cuid())
  deliveryId       String
  productId        String
  quantity         Int
  salesPrice       Decimal?
  discount         Decimal           @default(0)
  uom              String?
  vendorName       String            @default("UMUM")
  orderItemId      String?
  delivery         SalesDelivery     @relation(fields: [deliveryId], references: [id])
  orderItem        SalesOrderItem?   @relation(fields: [orderItemId], references: [id])
  product          Product           @relation(fields: [productId], references: [id])
  salesReturnItems SalesReturnItem[]
}

model SalesReturn {
  id           String            @id @default(cuid())
  returnNumber String            @unique
  date         DateTime          @default(now())
  deliveryId   String
  status       String            @default("PENDING")
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdById  String?
  isVoid       Boolean           @default(false)
  voidReason   String?
  createdBy    User?             @relation("SRCreatedBy", fields: [createdById], references: [id])
  delivery     SalesDelivery     @relation(fields: [deliveryId], references: [id])
  items        SalesReturnItem[]
}

model SalesReturnItem {
  id             String             @id @default(cuid())
  salesReturnId  String
  productId      String
  deliveryItemId String?
  quantity       Int
  reason         String?
  deliveryItem   SalesDeliveryItem? @relation(fields: [deliveryItemId], references: [id])
  product        Product            @relation(fields: [productId], references: [id])
  salesReturn    SalesReturn        @relation(fields: [salesReturnId], references: [id])
}

model Warehouse {
  id          String          @id @default(cuid())
  name        String
  location    String
  receipts    GoodsReceipt[]
  deliveries  SalesDelivery[]
  salesOrders SalesOrder[]
  stocks      Stock[]
  movements   StockMovement[]
}

model Product {
  id                  String                     @id @default(cuid())
  sku                 String                     @unique
  name                String
  brand               String?
  category            String?
  barcode             String?
  uom                 String?
  purchasePrice       Decimal                    @default(0)
  salesPrice          Decimal                    @default(0)
  lowStockThreshold   Int                        @default(10)
  createdById         String?
  receiptItems        GoodsReceiptItem[]
  verifications       GoodsReceiptVerification[]
  createdBy           User?                      @relation("ProductCreatedBy", fields: [createdById], references: [id])
  purchaseOrderItems  PurchaseOrderItem[]
  purchaseReturnItems PurchaseReturnItem[]
  salesItems          SalesDeliveryItem[]
  orderItems          SalesOrderItem[]
  salesReturnItems    SalesReturnItem[]
  stocks              Stock[]
  movements           StockMovement[]
}

model Stock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  vendorName  String    @default("UMUM")
  quantity    Int
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId, vendorName])
}

model StockMovement {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  vendorName  String?
  quantity    Int
  type        String
  reference   String?
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default("global")
  companyName String   @default("PT. Kola Borasi Indonesia")
  address     String   @default("Jl. Industri No. 12, Jakarta Pusat, DKI Jakarta")
  taxId       String   @default("01.234.567.8-012.000")
  website     String   @default("www.kolaborasi.id")
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String             @id @default(cuid())
  title     String
  message   String
  type      String             @default("info")
  authorId  String?
  createdAt DateTime           @default(now())
  author    User?              @relation("NotificationAuthor", fields: [authorId], references: [id])
  reads     NotificationRead[]
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
}
