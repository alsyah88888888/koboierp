// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- AUTH MODULE ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // ADMIN, FINANCE, PURCHASE, WAREHOUSE
  journals      JournalEntry[] @relation("JournalCreatedBy")
  password      String?
  accounts      Account[]
  sessions      Session[]
  requestedRequests PurchaseRequest[] @relation("RequestedBy")
  approvedRequests PurchaseRequest[]  @relation("ApprovedBy")
  verifiedRequests PurchaseRequest[]  @relation("VerifiedBy")
  notifications Notification[] @relation("NotificationAuthor")

  // Live Tracking
  goodsReceipts    GoodsReceipt[]     @relation("GRCreatedBy")
  salesDeliveries  SalesDelivery[]    @relation("SDCreatedBy")
  financeTrans     FinanceTransaction[] @relation("FTCreatedBy")
  products         Product[]          @relation("ProductCreatedBy")
  vendors          Vendor[]           @relation("VendorCreatedBy")
  customers        Customer[]         @relation("CustomerCreatedBy")
  salesReturns     SalesReturn[]      @relation("SRCreatedBy")
  purchaseReturns  PurchaseReturn[]   @relation("PRCreatedBy")
  salesOrders      SalesOrder[]       @relation("SOCreatedBy")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- FINANCE MODULE ---
model FinanceAccount {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  type      String   // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  journals  JournalEntry[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  description String
  amount      Decimal
  type        String   // DEBIT, CREDIT
  accountId   String
  account     FinanceAccount  @relation(fields: [accountId], references: [id])
  transactionId String?
  transaction   FinanceTransaction? @relation(fields: [transactionId], references: [id])

  createdById     String?
  createdBy       User?    @relation("JournalCreatedBy", fields: [createdById], references: [id])

  @@index([date])
  @@index([accountId])
  @@index([createdById])
}

model FinanceTransaction {
  id              String   @id @default(cuid())
  transactionType String   // PAYMENT, RECEIPT
  bank            String   // Bank Name / Method
  date            DateTime // Payment Date
  referenceNumber String?  // No Bukti Transfer
  description     String
  amount          Decimal
  category        String?  // Category for tracking
  salesPerson     String?  // Added for tracking sales expenses (e.g. BC, PF)
  journals        JournalEntry[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById     String?
  createdBy       User?    @relation("FTCreatedBy", fields: [createdById], references: [id])

  @@index([date])
  @@index([createdAt])
  @@index([createdById])
}

// --- PARTNER MODULE (Suppliers & Buyers) ---
model Vendor {
  id        String   @id @default(cuid())
  code      String?  @unique // ID Pemasok
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  province  String?
  postalCode String?
  npwp      String?
  taxName   String?  // Nama Wajib Pajak
  balance   Decimal  @default(0) // Hutang ke Vendor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchaseOrders PurchaseOrder[]

  createdById     String?
  createdBy       User?    @relation("VendorCreatedBy", fields: [createdById], references: [id])
}

model Customer {
  id        String   @id @default(cuid())
  code      String?  @unique // ID Pelanggan
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  province  String?
  postalCode String?
  npwp      String?
  taxName   String?  // Nama Wajib Pajak
  balance   Decimal  @default(0) // Piutang dari Customer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById     String?
  createdBy       User?    @relation("CustomerCreatedBy", fields: [createdById], references: [id])
}

// --- PURCHASE MODULE ---
model PurchaseOrder {
  id          String   @id @default(cuid())
  number      String   @unique
  date        DateTime @default(now())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  items       PurchaseOrderItem[]
  status      String   @default("PENDING") // PENDING, RECEIVED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([number])
  @@index([date])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  price           Decimal
}

model PurchaseRequest {
  id            String   @id @default(cuid())
  number        String   @unique // PR-YYYYMMDD-XXXX
  date          DateTime @default(now())
  status        String   @default("PENDING") // PENDING, APPROVED_BY_ADMIN, VERIFIED_BY_FINANCE, REJECTED
  category      String?  // PEMBELIAN, OPERASIONAL
  notes         String?
  salesPerson   String?  // BC, PF, or UMUM
  
  items         PurchaseRequestItem[]
  
  requestedById String
  requestedBy   User     @relation("RequestedBy", fields: [requestedById], references: [id])
  
  approvedById  String?
  approvedBy    User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  
  verifiedById  String?
  verifiedBy    User?    @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  itemName          String          // For office needs like "Komputer", "CCTV", etc.
  quantity          Int
  estimatedPrice    Decimal
}

model GoodsReceipt {
  id                String   @id @default(cuid())
  receiptNumber     String   @unique
  receivedFrom      String
  formNumber        String?  @unique
  date              DateTime?
  taxInvoiceDate    DateTime?
  taxInvoiceNumber  String?
  salesPerson       String?  // BC or PF
  warehouseId       String
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id])
  items             GoodsReceiptItem[]
  verifications     GoodsReceiptVerification[]
  isVerified        Boolean  @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?
  paymentStatus     String   @default("PENDING") // PENDING, PAID

  // Voiding system
  isVoid           Boolean  @default(false)
  voidReason       String?
  
  // New financial fields
  subtotal       Decimal  @default(0)
  totalDiscount  Decimal  @default(0)
  taxRate        Decimal  @default(0) // e.g. 0.11
  taxAmount      Decimal  @default(0)
  grandTotal     Decimal  @default(0)
  paidAmount     Decimal  @default(0)

  createdAt       DateTime @default(now())
  returns           PurchaseReturn[]

  createdById     String?
  createdBy       User?    @relation("GRCreatedBy", fields: [createdById], references: [id])

  @@index([receiptNumber])
  @@index([createdAt])
  @@index([date])
  @@index([paymentStatus])
}

model GoodsReceiptItem {
  id              String       @id @default(cuid())
  receiptId       String
  receipt         GoodsReceipt @relation(fields: [receiptId], references: [id])
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  quantity        Int
  purchasePrice   Decimal      @default(0)
  discount        Decimal      @default(0) // Manual Nominal Discount
  uom             String?
}

model GoodsReceiptVerification {
  id               String       @id @default(cuid())
  receiptId        String
  receipt          GoodsReceipt @relation(fields: [receiptId], references: [id])
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  expectedQuantity Int
  actualQuantity   Int
  expectedPrice    Decimal
  actualPrice      Decimal
  notes            String?
  createdAt        DateTime     @default(now())
  verifiedBy       String
}

model PurchaseReturn {
  id              String   @id @default(cuid())
  returnNumber    String   @unique // Format: RET-YYYYMMDD-XXX
  date            DateTime @default(now())
  
  receiptId       String
  receipt         GoodsReceipt @relation(fields: [receiptId], references: [id])
  
  status          String   @default("PENDING") // PENDING, APPROVED_BY_FINANCE
  notes           String?

  // Voiding system
  isVoid           Boolean  @default(false)
  voidReason       String?
  
  items           PurchaseReturnItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById     String?
  createdBy       User?    @relation("PRCreatedBy", fields: [createdById], references: [id])
}

model PurchaseReturnItem {
  id               String         @id @default(cuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  quantity         Int
  reason           String?
}

// --- SALES MODULE (PI -> PO -> SJ) ---
model SalesOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique // KB-TRN... or KB-TRD...
  proformaNumber  String?  @unique // KB-PI...
  poNumber        String?  // Buyer's PO (manual)
  status          String   @default("OPEN") // DRAFT (PI), OPEN, PARTIAL, CLOSED, CANCELLED
  
  recipient       String
  buyerName       String
  salesPerson     String?  // BC or PF
  date            DateTime @default(now())
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  
  // Financials
  subtotal        Decimal  @default(0)
  totalDiscount   Decimal  @default(0)
  taxRate         Decimal  @default(0)
  taxAmount       Decimal  @default(0)
  grandTotal      Decimal  @default(0)
  
  items           SalesOrderItem[]
  deliveries      SalesDelivery[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?
  createdBy       User?    @relation("SOCreatedBy", fields: [createdById], references: [id])

  @@index([orderNumber])
  @@index([proformaNumber])
  @@index([createdAt])
}

model SalesOrderItem {
  id              String         @id @default(cuid())
  orderId         String
  order           SalesOrder     @relation(fields: [orderId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Int            // Ordered Quantity
  shippedQuantity Int            @default(0) // Fulfilled Quantity
  salesPrice      Decimal
  discount        Decimal        @default(0)
  uom             String?
  vendorName      String         @default("UMUM")
  deliveryItems   SalesDeliveryItem[]
}

model SalesDelivery {
  id             String   @id @default(cuid())
  deliveryNumber String   @unique // No. Pengiriman (KB-SJ-YYYYMMDD-XXX-X)
  orderId        String?  // Link to SalesOrder
  order          SalesOrder? @relation(fields: [orderId], references: [id])
  poNumber       String?  // No. PO Buyer (Manual)
  recipient      String   // Kirim Ke
  buyerName      String   // Pengiriman ke Buyer
  vehicleNumber  String?  // No. Kendaraan & Driver
  salesPerson    String?  // BC or PF
  date           DateTime @default(now())
  items          SalesDeliveryItem[]
  warehouseId    String
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])
  paymentStatus  String   @default("PENDING") // PENDING, PAID
  
  // Voiding system
  isVoid           Boolean  @default(false)
  voidReason       String?

  // New financial fields
  subtotal       Decimal  @default(0)
  totalDiscount  Decimal  @default(0)
  taxRate        Decimal  @default(0) // e.g. 0.11
  taxAmount      Decimal  @default(0)
  grandTotal     Decimal  @default(0)
  paidAmount     Decimal  @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  returns        SalesReturn[]

  createdById     String?
  createdBy       User?    @relation("SDCreatedBy", fields: [createdById], references: [id])

  @@index([deliveryNumber])
  @@index([createdAt])
  @@index([date])
  @@index([paymentStatus])
}

model SalesDeliveryItem {
  id             String        @id @default(cuid())
  deliveryId     String
  delivery       SalesDelivery @relation(fields: [deliveryId], references: [id])
  orderItemId    String?
  orderItem      SalesOrderItem? @relation(fields: [orderItemId], references: [id])
  productId      String
  product        Product       @relation(fields: [productId], references: [id])
  quantity       Int
  salesPrice     Decimal?      // Added for financial tracking
  discount       Decimal       @default(0) // Discount per item
  uom            String?       // Unit of Measure
  vendorName     String        @default("UMUM") // To track which vendor stock was deducted
  salesReturnItems SalesReturnItem[]
}

model SalesReturn {
  id              String   @id @default(cuid())
  returnNumber    String   @unique // Format: SRET-YYYYMMDD-XXX
  date            DateTime @default(now())
  
  deliveryId      String
  delivery        SalesDelivery @relation(fields: [deliveryId], references: [id])
  
  status          String   @default("PENDING") // PENDING, VERIFIED_BY_FINANCE
  notes           String?

  // Voiding system
  isVoid           Boolean  @default(false)
  voidReason       String?
  
  items           SalesReturnItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById     String?
  createdBy       User?    @relation("SRCreatedBy", fields: [createdById], references: [id])
}

model SalesReturnItem {
  id               String         @id @default(cuid())
  salesReturnId    String
  salesReturn      SalesReturn    @relation(fields: [salesReturnId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  deliveryItemId   String?
  deliveryItem     SalesDeliveryItem? @relation(fields: [deliveryItemId], references: [id])
  quantity         Int
  reason           String?
}

// --- WAREHOUSE MODULE ---
model Warehouse {
  id       String   @id @default(cuid())
  name     String
  location String
  stocks   Stock[]
  receipts GoodsReceipt[]
  deliveries SalesDelivery[]
  salesOrders SalesOrder[]
  movements StockMovement[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  brand       String?
  category    String?
  barcode     String?
  uom               String?   // Unit of Measure
  purchasePrice     Decimal   @default(0)
  salesPrice        Decimal   @default(0)
  lowStockThreshold Int       @default(10)
  stocks      Stock[]
  receiptItems GoodsReceiptItem[]
  verifications GoodsReceiptVerification[]
  salesItems   SalesDeliveryItem[]
  purchaseOrderItems PurchaseOrderItem[]
  purchaseReturnItems PurchaseReturnItem[]
  salesReturnItems    SalesReturnItem[]
  orderItems          SalesOrderItem[]
  movements StockMovement[]

  createdById     String?
  createdBy       User?    @relation("ProductCreatedBy", fields: [createdById], references: [id])
}

model Stock {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  vendorName  String   @default("UMUM") // To track which vendor this stock came from
  quantity    Int
  @@unique([productId, warehouseId, vendorName])
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  vendorName  String?  // Optional, tracks which vendor stock was affected
  quantity    Int      // Positive for in, negative for out
  type        String   // GOODS_RECEIPT, SALE, ADJUSTMENT
  reference   String?  // Receipt Number or Transaction ID
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
}

model SystemSetting {
  id        String   @id @default("global")
  companyName String @default("PT. Kola Borasi Indonesia")
  address     String @default("Jl. Industri No. 12, Jakarta Pusat, DKI Jakarta")
  taxId       String @default("01.234.567.8-012.000")
  website     String @default("www.kolaborasi.id")
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info, alert, broadcast, success
  authorId  String?
  author    User?    @relation("NotificationAuthor", fields: [authorId], references: [id])
  reads     NotificationRead[]
  createdAt DateTime @default(now())
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
}
